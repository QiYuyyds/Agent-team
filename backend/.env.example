# AgentHub Python Backend Environment Variables

# Database
DATABASE_URL=sqlite+aiosqlite:///../.agenthub-data/agenthub.db

# API Keys (optional, can also be set in app settings)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ARK_API_KEY=

# Server
HOST=127.0.0.1
PORT=8000
DEBUG=false

# CORS (for frontend)
CORS_ORIGINS=http://localhost:3000

# Workspace
WORKSPACE_ROOT=../.agenthub-data/workspaces
