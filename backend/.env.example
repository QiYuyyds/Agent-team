# AgentHub Python Backend Environment Variables

# ═══════════════════════════════════════════════════════════
# Database (PostgreSQL)
# ═══════════════════════════════════════════════════════════
DATABASE_URL=postgresql+asyncpg://agenthub:agenthub@localhost:5432/agenthub

# ═══════════════════════════════════════════════════════════
# API Keys (optional, can also be set in app settings)
# ═══════════════════════════════════════════════════════════
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ARK_API_KEY=

# ═══════════════════════════════════════════════════════════
# Web Search (Tavily)
# ═══════════════════════════════════════════════════════════
# Required for the web_search tool. Leave empty to disable web search
# (the tool returns a clear error when called without a key).
TAVILY_API_KEY=

# ═══════════════════════════════════════════════════════════
# Server
# ═══════════════════════════════════════════════════════════
HOST=127.0.0.1
PORT=8000
DEBUG=false

# ═══════════════════════════════════════════════════════════
# CORS (for frontend)
# ═══════════════════════════════════════════════════════════
CORS_ORIGINS=http://localhost:3000

# ═══════════════════════════════════════════════════════════
# Workspace & Data Directory
# ═══════════════════════════════════════════════════════════
WORKSPACE_ROOT=../.agenthub-data/workspaces
DATA_DIR=../.agenthub-data

# ═══════════════════════════════════════════════════════════
# Milvus (Vector Database)
# ═══════════════════════════════════════════════════════════
# Leave empty to disable Milvus (degraded to TF cosine memory search)
MILVUS_HOST=localhost
MILVUS_PORT=19530

# ═══════════════════════════════════════════════════════════
# Elasticsearch (Full-Text Search)
# ═══════════════════════════════════════════════════════════
# Leave empty to disable ES (no full-text retrieval)
ES_ADDRESSES=http://localhost:9200

# ═══════════════════════════════════════════════════════════
# Neo4j (Knowledge Graph)
# ═══════════════════════════════════════════════════════════
# Leave empty to disable Neo4j (GraphMemory becomes no-op)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here
ENABLE_GRAPH=false
KG_MAX_HOPS=2
KG_WEIGHT=0.3

# ═══════════════════════════════════════════════════════════
# Kafka (Optional Event Bus Enhancement)
# ═══════════════════════════════════════════════════════════
# Leave empty to use InProcess EventBus only
KAFKA_BROKERS=localhost:9092

# ═══════════════════════════════════════════════════════════
# Embedding Model Configuration
# ═══════════════════════════════════════════════════════════
# Required for semantic search (Milvus/LTM recall)
EMBEDDING_API_KEY=
EMBEDDING_API_URL=
EMBEDDING_MODEL=

# ═══════════════════════════════════════════════════════════
# RAG System Configuration
# ═══════════════════════════════════════════════════════════
RAG_CHUNK_SIZE=200
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=3
RAG_RRF_CONSTANT_K=60
RAG_SEMANTIC_WEIGHT=0.7
RAG_MILVUS_DIM=1024
RAG_REWRITE_ENABLED=true
RAG_REWRITE_NUM_QUERIES=3
RAG_RERANK_ENABLED=true
RAG_RERANK_PREVIEW_LEN=200

# ═══════════════════════════════════════════════════════════
# Memory System Configuration
# ═══════════════════════════════════════════════════════════
MEMORY_SHORT_TERM_MAX_TURNS=10
MEMORY_LONG_TERM_TOP_K=3
MEMORY_CONSOLIDATION_SIMILARITY=0.80
MEMORY_CONSOLIDATION_DEDUP=0.95
MEMORY_CONSOLIDATION_TTL_DAYS=30
MEMORY_CONSOLIDATION_DECAY_RATE=0.995
MEMORY_CONSOLIDATION_MIN_IMPORTANCE=0.3
MEMORY_CONSOLIDATION_TRIGGER=5
