# API Keys for AI providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
# 火山方舟 (Volcano Ark) — 走豆包多模态模型用这个
ARK_API_KEY=

# Optional: override default Orchestrator model
# ORCHESTRATOR_PROVIDER=anthropic
# ORCHESTRATOR_MODEL_ID=claude-opus-4-7

# Point the React frontend at the standalone Python (FastAPI) backend.
# Leave empty for same-origin (Next.js built-in API). Set to the Python
# backend origin when running it separately, e.g. http://localhost:8000
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
